# ── WhatsApp Moderation Bot — configuration template ──
# Copy this file to ".env" and fill in your own values.

# The group the bot moderates. Leave empty on first run: the bot prints incoming
# chat IDs to the terminal so you can find your group's ID (ends with @g.us).
GROUP_ID=

# Groq API key for AI roasts/replies — get a free key at https://console.groq.com/keys
GROQ_API_KEY=
# Optional: override the model (default: llama-3.3-70b-versatile)
GROQ_MODEL=

# THE BIG BOSS — bot obeys these and treats them as a yes-man.
# Use the @lid number (shown in logs) and/or the phone number, comma-separated.
BOSS_IDS=

# CO-ADMINS — respected and able to command the bot.
COADMIN_IDS=
COADMIN_TITLE=Co-Admin

# The bot's own @lid (so @mentions of the bot are recognized).
# Discover it from the logs on first run, then paste it here.
BOT_IDS=

# Optional keyword trigger in addition to @mention/reply. Empty = disabled.
BOT_KEYWORD=
